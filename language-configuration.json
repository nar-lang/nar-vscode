{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{",  "close": "}" },
        { "open": "[",  "close": "]" },
        { "open": "(",  "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'",  "close": "'",  "notIn": ["string"] },
        { "open": "/*", "close": "*/", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*(\\{|\\[|\\(|=>|=|then|else|let|in|case|select)\\s*$",
        "decreaseIndentPattern": "^\\s*(\\}|\\]|\\)|end)"
    },
    "wordPattern": "[A-Za-z_][A-Za-z0-9_]*"
}
